# ClassPing — environment variables
#
# Copy to .env.local and fill in. `.env*` is gitignored, so .env.local never
# leaves your machine. The same keys must also exist in the Vercel project
# (Settings → Environment Variables) for Preview and Production.

# ── Clerk: authentication + billing ──────────────────────────────────────────
# Dashboard → API Keys. The publishable key ships to the browser (safe);
# the secret key is server-only and must never be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Keep auth on our own sign-in screen ("/") instead of Clerk's hosted pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/home
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/home

# ── Neon Postgres: Pro cloud sync ────────────────────────────────────────────
# Provisioned through the Vercel Marketplace. OPTIONAL: leave it unset and the
# app still runs — /api/sync returns 503 and the client keeps working offline
# against localStorage. Verify a real connection with: node scripts/check-db.mjs
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── Web Push (VAPID): the after-class nudge ──────────────────────────────────
# Standard VAPID — we sign each push ourselves and hand it to the browser's own
# push service (FCM / Mozilla / Apple). No vendor SDK, no per-message cost.
#
# Generate the pair ONCE with:  node scripts/generate-vapid.mjs
#
# Rotating these invalidates every existing subscription — every user silently
# stops getting notifications until they re-subscribe. Treat them as permanent.
# Only the public key may be NEXT_PUBLIC_; the private key signs pushes and must
# stay server-side. OPTIONAL: unset and the push routes return 503, the Settings
# toggle hides itself, and the rest of the app is unaffected.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A mailto: or https: URL you control — push services use it to reach you if
# your pushes start misbehaving.
VAPID_SUBJECT=mailto:you@example.com

# Shared secret for the cron. Vercel Cron sends it as `Authorization: Bearer …`;
# without it, /api/cron/post-class is a public button that notifies every user
# on demand. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=
