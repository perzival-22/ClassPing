# ClassPing — environment variables
#
# Copy to .env.local and fill in. `.env*` is gitignored, so .env.local never
# leaves your machine. The same keys must also exist in the Vercel project
# (Settings → Environment Variables) for Preview and Production.

# ── Clerk: authentication + billing ──────────────────────────────────────────
# Dashboard → API Keys. The publishable key ships to the browser (safe);
# the secret key is server-only and must never be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Keep auth on our own sign-in screen ("/") instead of Clerk's hosted pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/home
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/home

# ── Neon Postgres: Pro cloud sync ────────────────────────────────────────────
# Provisioned through the Vercel Marketplace. OPTIONAL: leave it unset and the
# app still runs — /api/sync returns 503 and the client keeps working offline
# against localStorage. Verify a real connection with: node scripts/check-db.mjs
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
